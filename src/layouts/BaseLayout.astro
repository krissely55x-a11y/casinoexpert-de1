---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogLocale?: string;
  ogType?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  twitterCard?: string;
  jsonLd?: string;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogLocale = 'de_AT',
  ogType = 'website',
  ogTitle = title,
  ogDescription = description,
  ogUrl = canonical,
  ogImage = '',
  twitterCard = 'summary_large_image',
  jsonLd = '',
  bodyClass = '',
} = Astro.props;

const site = Astro.site?.href.replace(/\/$/, '') ?? 'https://onlinecasinoexperte.org';
const routePath = Astro.url.pathname.startsWith('/') ? Astro.url.pathname : `/${Astro.url.pathname}`;
const resolvePageUrl = (value: string) => {
  if (value.startsWith('http')) return value;
  if (value.startsWith('/') && !value.startsWith('/..')) return `${site}${value}`;
  return `${site}${routePath}`;
};
const canonicalUrl = resolvePageUrl(canonical);
const ogPageUrl = resolvePageUrl(ogUrl);
const ogImageUrl = ogImage
  ? ogImage.startsWith('http')
    ? ogImage
    : `${site}/${ogImage.replace(/^\//, '')}`
  : '';
---

<!DOCTYPE html>
<html lang="de-AT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogPageUrl} />
    <meta property="og:site_name" content="OnlineCasinoExperte.org" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:site" content="@CasinoExperte" />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <link rel="stylesheet" href="/styles/legacy.css" />
    <link rel="stylesheet" href="/styles/theme.css" />
    <style is:global>
      :root {
        clip-path: none !important;
        width: auto !important;
        height: auto !important;
        margin: 0 !important;
        overflow: visible !important;
        position: static !important;
      }
      .gm-navbar,
      .space-page-content,
      main {
        opacity: 1 !important;
        visibility: visible !important;
      }
      .fa,
      .gmi {
        font-family: Arial, sans-serif !important;
      }
      .fa-angle-down::before { content: "⌄"; }
      .fa-bars::before { content: "☰"; }
      .fa-times::before { content: "×"; }
      .fa-star::before { content: "★"; }
      .fa-star-o::before { content: "☆"; }
      .fa-star-half-o::before { content: "★"; }
      .gmi-zoom-search::before { content: "⌕"; }
      .cky-btn-revisit-wrapper.cky-revisit-bottom-left {
        display: none !important;
        visibility: hidden !important;
      }
    </style>
  </head>
  <body ontouchstart class={bodyClass}>
    <Header />
    <div class="space-box relative">
      <slot />
      <Footer />
    </div>
  </body>
</html>
